# k8s-mcp Docker / local config
# Copy to .env and fill in values

# Required when auth is enabled (recommended for Docker)
K8S_MCP_AUTH_TOKEN=your-secret-token-here

# Optional: override host/port (default 0.0.0.0:8000)
K8S_MCP_HOST=0.0.0.0
K8S_MCP_PORT=8000

# 排查时设为 DEBUG
# K8S_MCP_LOG_LEVEL=DEBUG

# For docker-compose: path to kubeconfig
# 若默认 ~/.kube/config 无法解析，请显式设置
KUBECONFIG_PATH=${HOME}/.kube/config
